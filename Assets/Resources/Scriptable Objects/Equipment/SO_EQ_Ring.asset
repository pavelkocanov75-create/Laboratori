  _header: "\u041A\u043E\u043B\u044C\u0446\u043E \u0440\u0430\u0437\u0440\u0435\u0437\u043D\u043E\u0435"
  _description: "\u0418\u0441\xAD\u043F\u043E\u043B\u044C\xAD\u0437\u0443\xAD\u0435\u0442\xAD\u0441\u044F
    \u0434\u043B\u044F \u0444\u0438\u043A\xAD\u0441\u0430\xAD\u0446\u0438\u0438 \u043A\u043E\u043B\u0431,
    \u0434\u0435\xAD\u043B\u0438\xAD\u0442\u0435\u043B\u044C\xAD\u043D\u044B\u0445
    \u0432\u043E\xAD\u0440\u043E\xAD\u043D\u043E\u043A \u0438 \u043F\u0440\u043E\xAD\u0447\u0435\u0439
    \u043B\u0430\xAD\u0431\u043E\xAD\u0440\u0430\xAD\u0442\u043E\u0440\xAD\u043D\u043E\u0439
    \u043F\u043E\xAD\u0441\u0443\xAD\u0434\u044B \u043D\u0430 \u043B\u0430\xAD\u0431\u043E\xAD\u0440\u0430\xAD\u0442\u043E\u0440\xAD\u043D\u044B\u0445
    \u0448\u0442\u0430\xAD\u0442\u0438\xAD\u0432\u0430\u0445, \u0430 \u0442\u0430\u043A\xAD\u0436\u0435
    \u0432 \u0440\u0430\u0437\xAD\u043B\u0438\u0447\xAD\u043D\u044B\u0445 \u043B\u0430\xAD\u0431\u043E\xAD\u0440\u0430\xAD\u0442\u043E\u0440\xAD\u043D\u044B\u0445
    \u043F\u0440\u0438\xAD\u0431\u043E\xAD\u0440\u0430\u0445 \u0438 \u0443\u0441\u0442\u0430\xAD\u043D\u043E\u0432\xAD\u043A\u0430\u0445.
    \u041A\u043E\u043B\u044C\xAD\u0446\u043E \u0434\u0438\u0430\xAD\u043C\u0435\u0442\xAD\u0440\u043E\u043C
    85 \u043C\u043C."
