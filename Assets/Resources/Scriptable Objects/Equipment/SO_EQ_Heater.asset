  _header: "\u041D\u0430\u0433\u0440\u0435\u0432\u0430\u0442\u0435\u043B\u044C \u043F\u0440\u043E\u0431\u0438\u0440\u043E\u043A"
  _description: "\u041D\u0430\xAD\u0433\u0440\u0435\xAD\u0432\u0430\xAD\u0442\u0435\u043B\u044C
    \u043F\u0440\u0435\u0434\xAD\u043D\u0430\xAD\u0437\u043D\u0430\xAD\u0447\u0435\u043D
    \u0434\u043B\u044F \u043D\u0430\xAD\u0433\u0440\u0435\xAD\u0432\u0430\xAD\u043D\u0438\u044F
    \u0432 \u043F\u0440\u043E\xAD\u0431\u0438\u0440\xAD\u043A\u0430\u0445 \xF8 14
    \u043C\u043C \u0432\u0435\xAD\u0449\u0435\u0441\u0442\u0432, \u043A\u0440\u043E\xAD\u043C\u0435
    \u0433\u043E\xAD\u0440\u044E\xAD\u0447\u0438\u0445 \u0438 \u043B\u0435\u0433\xAD\u043A\u043E\xAD\u0432\u043E\u0441\xAD\u043F\u043B\u0430\xAD\u043C\u0435\xAD\u043D\u044F\xAD\u044E\xAD\u0449\u0438\u0445\xAD\u0441\u044F,
    \u043F\u0440\u0438 \u043F\u0440\u043E\xAD\u0432\u0435\xAD\u0434\u0435\xAD\u043D\u0438\u0438
    \u0443\u0447\u0435\u0431\xAD\u043D\u044B\u0445 \u043B\u0430\xAD\u0431\u043E\xAD\u0440\u0430\xAD\u0442\u043E\u0440\xAD\u043D\u044B\u0445
    \u043E\u043F\u044B\xAD\u0442\u043E\u0432. \u0417\u0430\xAD\u043A\u0440\u0435\u043F\xAD\u043B\u044F\xAD\u0435\u0442\xAD\u0441\u044F
    \u0432 \u043C\u0443\u0444\xAD\u0442\u0435 \u043B\u0430\xAD\u0431\u043E\xAD\u0440\u0430\xAD\u0442\u043E\u0440\xAD\u043D\u043E\xAD\u0433\u043E
    \u0448\u0442\u0430\xAD\u0442\u0438\xAD\u0432\u0430 \u043C\u0438\u043A\xAD\u0440\u043E\xAD\u043B\u0430\xAD\u0431\u043E\xAD\u0440\u0430\xAD\u0442\u043E\xAD\u0440\u0438\u0438
    \u0434\u043B\u044F \u0445\u0438\xAD\u043C\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\xAD\u0433\u043E
    \u044D\u043A\u0441\xAD\u043F\u0435\xAD\u0440\u0438\xAD\u043C\u0435\u043D\xAD\u0442\u0430.
    \u041D\u0430\xAD\u0433\u0440\u0435\xAD\u0432\u0430\xAD\u0442\u0435\u043B\u044C
    \u0441\u043D\u0430\u0431\xAD\u0436\u0435\u043D \u0448\u043D\u0443\xAD\u0440\u043E\u043C
    \u0441 \u0432\u0438\u043B\xAD\u043A\u043E\u0439, \u0441\u043E\xAD\u0433\u043B\u0430\xAD\u0441\u043E\xAD\u0432\u0430\u043D\xAD\u043D\u043E\u0439
    \u0441 \u0448\u043A\u043E\u043B\u044C\xAD\u043D\u043E\u0439 \u0440\u043E\xAD\u0437\u0435\u0442\xAD\u043A\u043E\u0439
    \u043B\u0430\xAD\u0431\u043E\xAD\u0440\u0430\xAD\u0442\u043E\u0440\xAD\u043D\u043E\xAD\u0433\u043E
    \u0441\u0442\u043E\xAD\u043B\u0430, \u0434\u043B\u044F \u0432\u043A\u043B\u044E\xAD\u0447\u0435\xAD\u043D\u0438\u044F
    \u0432 \u044D\u043B\u0435\u043A\xAD\u0442\u0440\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0443\u044E
    \u0441\u0435\u0442\u044C \u043F\u0435\xAD\u0440\u0435\xAD\u043C\u0435\u043D\xAD\u043D\u043E\xAD\u0433\u043E
    \u0442\u043E\xAD\u043A\u0430 \u0447\u0430\u0441\xAD\u0442\u043E\xAD\u0442\u043E\u0439
    50 \u0413\u0446, \u043D\u0430\xAD\u043F\u0440\u044F\xAD\u0436\u0435\xAD\u043D\u0438\xAD\u0435\u043C
    42 \u0412."
