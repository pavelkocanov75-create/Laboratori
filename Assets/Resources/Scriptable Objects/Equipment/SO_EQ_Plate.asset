  _header: "\u0412\u044B\u043F\u0430\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u043F\u043B\u0430\u0441\u0442\u0438\u043D\u0430"
  _description: "\u0412\u044B\xAD\u043F\u0430\xAD\u0440\u0438\xAD\u0442\u0435\u043B\u044C\xAD\u043D\u0430\u044F
    \u043F\u043B\u0430\u0441\xAD\u0442\u0438\xAD\u043D\u0430 \u0438\u0441\xAD\u043F\u043E\u043B\u044C\xAD\u0437\u0443\xAD\u0435\u0442\xAD\u0441\u044F
    \u0434\u043B\u044F \u0432\u044B\xAD\u043F\u0430\xAD\u0440\u0438\xAD\u0432\u0430\xAD\u043D\u0438\u044F
    (\u0443\u043F\u0430\xAD\u0440\u0438\xAD\u0432\u0430\xAD\u043D\u0438\u044F) \u043D\u0435\xAD\u0431\u043E\u043B\u044C\xAD\u0448\u043E\xAD\u0433\u043E
    \u043A\u043E\xAD\u043B\u0438\xAD\u0447\u0435\u0441\u0442\xAD\u0432\u0430 \u0445\u0438\xAD\u043C\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0438\u0445
    \u0432\u0435\xAD\u0449\u0435\u0441\u0442\u0432 \u0434\u043E \u0441\u0443\xAD\u0445\u043E\xAD\u0433\u043E
    \u043E\u0441\u0442\u0430\u0442\xAD\u043A\u0430. \u041F\u0440\u0438\xAD\u0431\u043E\u0440
    \u043D\u0430 \u0444\u043E\xAD\u0442\u043E \u0434\u0438\u0430\xAD\u043C\u0435\u0442\xAD\u0440\u043E\u043C
    5,6 \u0441\u043C \u0438\u043C\u0435\xAD\u0435\u0442 3 \u043B\u0443\u043D\xAD\u043A\u0438
    (\u044F\u0447\u0435\u0439\xAD\u043A\u0438) \u0434\u0438\u0430\xAD\u043C\u0435\u0442\xAD\u0440\u043E\u043C
    2 \u0441\u043C. \u041F\u043B\u0430\u0441\xAD\u0442\u0438\xAD\u043D\u0430 \u0441
    \u0433\u043B\u0430\xAD\u0437\u0443\xAD\u0440\u043E\xAD\u0432\u0430\u043D\xAD\u043D\u044B\u043C
    \u043F\u043E\xAD\u043A\u0440\u044B\xAD\u0442\u0438\xAD\u0435\u043C \u0438\u0437\xAD\u0433\u043E\xAD\u0442\u043E\u0432\xAD\u043B\u0435\xAD\u043D\u0430
    \u0438\u0437 \u0444\u0430\u0440\xAD\u0444\u043E\u0440."
