  _header: "\u0411\u0443\u043C\u0430\u0436\u043D\u044B\u0439 \u0444\u0438\u043B\u044C\u0442\u0440"
  _description: "\u0424\u0438\u043B\u044C\xAD\u0442\u0440\u044B \u0431\u0443\xAD\u043C\u0430\u0436\xAD\u043D\u044B\u0435
