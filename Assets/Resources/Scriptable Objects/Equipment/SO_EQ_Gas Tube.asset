  _header: "\u0413\u0430\u0437\u043E\u0432\u0430\u044F \u0442\u0440\u0443\u0431\u043A\u0430"
  _description: "\u041F\u0440\u0435\u0434\xAD\u043D\u0430\xAD\u0437\u043D\u0430\xAD\u0447\u0430\xAD\u0435\u0442\xAD\u0441\u044F
    \u0434\u043B\u044F \u043E\u0442\u0432\u043E\xAD\u0434\u0430 \u0432\u044B\xAD\u0434\u0435\xAD\u043B\u044F\xAD\u044E\xAD\u0449\u0435\xAD\u0433\u043E\xAD\u0441\u044F
    \u0433\u0430\xAD\u0437\u0430 \u0438\u0437 \u0435\u043C\xAD\u043A\u043E\u0441\xAD\u0442\u0438.
    \u0420\u0435\xAD\u0437\u0438\xAD\u043D\u043E\xAD\u0432\u0430\u044F \u043F\u0440\u043E\u0431\xAD\u043A\u0430
    \u0441 \u043E\u0442\u0432\u0435\u0440\xAD\u0441\u0442\u0438\xAD\u0435\u043C d=5-6
    \u043C\u043C, \u0432 \u043A\u043E\xAD\u0442\u043E\xAD\u0440\u043E\u0435 \u0432\u0441\u0442\u0430\u0432\xAD\u043B\u0435\xAD\u043D\u0430
    \u0442\u0440\u0443\u0431\xAD\u043A\u0430 \u043F\u043E\u0434 \u0443\u0433\xAD\u043B\u043E\u043C
    90 \u0433\u0440\u0430\xAD\u0434\u0443\xAD\u0441\u043E\u0432. \u0422\u0440\u0443\u0431\xAD\u043A\u0430
    \u0441\u0442\u0435\u043A\xAD\u043B\u044F\u043D\xAD\u043D\u0430\u044F \u0433\u0430\xAD\u0437\u043E\xAD\u043E\u0442\xAD\u0432\u043E\u0434\xAD\u043D\u0430\u044F
    \u0438\u0437\xAD\u0433\u043E\xAD\u0442\u043E\u0432\xAD\u043B\u0435\xAD\u043D\u0430
    \u0438\u0437 \u0441\u0442\u0435\u043A\xAD\u043B\u0430 \u043C\u0430\u0440\xAD\u043A\u0438
    \u0422\u0421, d=5-6 \u043C\u043C, \u0443\u0433\u043E\u043B=90 \u0433\u0440\u0430\xAD\u0434\u0443\xAD\u0441\u043E\u0432."
