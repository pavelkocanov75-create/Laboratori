  _header: "\u041F\u0440\u0435\u0434\u043C\u0435\u0442\u043D\u043E\u0435 \u0441\u0442\u0435\u043A\u043B\u043E"
  _description: "\u041F\u0440\u0435\u0434\xAD\u043D\u0430\xAD\u0437\u043D\u0430\xAD\u0447\u0435\xAD\u043D\u043E
    \u0434\u043B\u044F \u043F\u0440\u0438\xAD\u0433\u043E\xAD\u0442\u043E\u0432\xAD\u043B\u0435\xAD\u043D\u0438\u044F
    \u0432\u0440\u0435\xAD\u043C\u0435\u043D\xAD\u043D\u044B\u0445 \u043C\u0438\u043A\xAD\u0440\u043E\u043F\xAD\u0440\u0435\xAD\u043F\u0430\xAD\u0440\u0430\xAD\u0442\u043E\u0432
    \u043F\u0440\u0438 \u0440\u0430\xAD\u0431\u043E\xAD\u0442\u0435 \u0441 \u043C\u0438\u043A\xAD\u0440\u043E\xAD\u0441\u043A\u043E\xAD\u043F\u043E\u043C,
    \u0430 \u0442\u0430\u043A \u0436\u0435 \u0432 \u043B\u0430\xAD\u0431\u043E\xAD\u0440\u0430\xAD\u0442\u043E\u0440\xAD\u043D\u044B\u0445
    \u043E\u043F\u044B\xAD\u0442\u0430\u0445 \u043F\u043E \u0445\u0438\xAD\u043C\u0438\u0438
    \u0434\u043B\u044F \u043F\u043B\u0430\u0432\xAD\u043B\u0435\xAD\u043D\u0438\u044F
    \u0438\u043B\u0438 \u0432\u044B\xAD\u043F\u0430\xAD\u0440\u0438\xAD\u0432\u0430\xAD\u043D\u0438\u044F
    \u0432\u0435\xAD\u0449\u0435\u0441\u0442\u0432. \u0413\u0430\xAD\u0431\u0430\xAD\u0440\u0438\u0442\xAD\u043D\u044B\u0435
    \u0440\u0430\u0437\xAD\u043C\u0435\xAD\u0440\u044B 76\u044526 \u043C\u043C."
