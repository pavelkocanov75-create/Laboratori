  _header: "\u0412\u043E\u0440\u043E\u043D\u043A\u0430"
  _description: "\u0418\u0441\xAD\u043F\u043E\u043B\u044C\xAD\u0437\u0443\xAD\u0435\u0442\xAD\u0441\u044F
    \u0434\u043B\u044F \u043F\u0435\xAD\u0440\u0435\xAD\u043B\u0438\xAD\u0432\u0430\xAD\u043D\u0438\u044F
    \u0436\u0438\u0434\xAD\u043A\u043E\u0441\xAD\u0442\u0435\u0439 \u0438 \u043F\u0435\xAD\u0440\u0435\xAD\u0441\u044B\xAD\u043F\u0430\xAD\u043D\u0438\u044F
    \u043F\u043E\xAD\u0440\u043E\u0448\xAD\u043A\u043E\u0432 \u0447\u0435\xAD\u0440\u0435\u0437
    \u0443\u0437\xAD\u043A\u0438\u0435 \u043F\u0440\u0438\xAD\u0451\u043C\xAD\u043D\u044B\u0435
    \u043E\u0442\u0432\u0435\u0440\xAD\u0441\u0442\u0438\u044F, \u0444\u0438\u043B\u044C\xAD\u0442\u0440\u043E\xAD\u0432\u0430\xAD\u043D\u0438\u044F,
    \u0430 \u0442\u0430\u043A\xAD\u0436\u0435 \u0434\u043E\xAD\u0437\u0438\xAD\u0440\u043E\xAD\u0432\u0430\xAD\u043D\u0438\u044F
    \u0440\u0430\u0437\xAD\u043B\u0438\u0447\xAD\u043D\u044B\u0445 \u0432\u0435\xAD\u0449\u0435\u0441\u0442\u0432.
    \u0418\u043C\u0435\xAD\u0435\u0442 \u0444\u043E\u0440\xAD\u043C\u0443 \u043F\u043E\xAD\u043B\u043E\xAD\u0433\u043E
    \u043A\u043E\xAD\u043D\u0443\xAD\u0441\u0430, \u0441\u0443\xAD\u0436\u0435\xAD\u043D\u0438\u0435
    \u043A\u043E\xAD\u0442\u043E\xAD\u0440\u043E\xAD\u0433\u043E \u043F\u0440\u043E\xAD\u0434\u043E\u043B\xAD\u0436\u0430\xAD\u0435\u0442
    \u0442\u0440\u0443\u0431\xAD\u043A\u0430."
