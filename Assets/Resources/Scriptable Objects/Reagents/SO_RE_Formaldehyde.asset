  _header: "\u0424\u043E\u0440\u043C\u0430\u043B\u044C\u0434\u0435\u0433\u0438\u0434"
  _description: "<b>HCHO</b>. \u0424\u043E\u0440\xAD\u043C\u0430\u043B\u044C\xAD\u0434\u0435\xAD\u0433\u0438\u0434
    - \u0433\u0430\xAD\u0437\u043E\xAD\u043E\u0431\xAD\u0440\u0430\u0437\xAD\u043D\u043E\u0435
    \u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u043E\u0435 \u0432\u0435\xAD\u0449\u0435\u0441\u0442\xAD\u0432\u043E,
    \u043E\u0431\xAD\u043B\u0430\xAD\u0434\u0430\xAD\u044E\xAD\u0449\u0435\u0435
    \u0432\u044B\xAD\u0441\u043E\xAD\u043A\u043E\u0439 \u0445\u0438\xAD\u043C\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0439
    \u0438 \u0431\u0438\u043E\xAD\u043B\u043E\xAD\u0433\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0439
    \u0430\u043A\xAD\u0442\u0438\u0432\xAD\u043D\u043E\u0441\u0442\u044C\u044E, \u0445\u043E\xAD\u0440\u043E\xAD\u0448\u043E
    \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0438\xAD\u043C\u043E\u0435
    \u0432 \u0432\u043E\xAD\u0434\u0435 \u0438 \u0441\u043F\u0438\u0440\xAD\u0442\u0430\u0445.
    \u0424\u043E\u0440\xAD\u043C\u0430\u043B\u044C\xAD\u0434\u0435\xAD\u0433\u0438\u0434
    \u043B\u0435\u0433\xAD\u043A\u043E (\u0438\u043D\u043E\u0433\xAD\u0434\u0430
    \u0441\u0430\xAD\u043C\u043E\xAD\u043F\u0440\u043E\xAD\u0438\u0437\xAD\u0432\u043E\u043B\u044C\xAD\u043D\u043E)
    \u043F\u043E\xAD\u043B\u0438\xAD\u043C\u0435\xAD\u0440\u0438\xAD\u0437\u0443\xAD\u0435\u0442\xAD\u0441\u044F
    \u0441 \u043E\u0431\xAD\u0440\u0430\xAD\u0437\u043E\xAD\u0432\u0430\xAD\u043D\u0438\xAD\u0435\u043C
    \u0440\u0430\u0437\xAD\u043B\u0438\u0447\xAD\u043D\u044B\u0445 \u0442\u0432\u0435\u0440\xAD\u0434\u044B\u0445
    \u0444\u043E\u0440\u043C \u0444\u043E\u0440\xAD\u043C\u0430\u043B\u044C\xAD\u0434\u0435\xAD\u0433\u0438\xAD\u0434\u0430
    - (CH<size=60%><b>2</b></size>=O)n : \u0442\u0440\u0438\xAD\u043E\u043A\xAD\u0441\u0430\u043D,
    \u0442\u0435\u0442\xAD\u0440\u0430\xAD\u043E\u043A\xAD\u0441\u0430\u043D, \u043F\u043E\xAD\u043B\u0438\xAD\u0444\u043E\u0440\xAD\u043C\u0430\u043B\u044C\xAD\u0434\u0435\xAD\u0433\u0438\u0434,
    \u043F\u0430\xAD\u0440\u0430\xAD\u0444\u043E\u0440\xAD\u043C\u0430\u043B\u044C\xAD\u0434\u0435\xAD\u0433\u0438\u0434,
    \u043F\u043E\xAD\u043B\u0438\xAD\u043E\u043A\xAD\u0441\u0438\xAD\u043C\u0435\xAD\u0442\u0438\xAD\u043B\u0435\u043D."
