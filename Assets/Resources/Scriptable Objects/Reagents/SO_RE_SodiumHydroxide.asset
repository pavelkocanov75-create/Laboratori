  _header: "\u0413\u0438\u0434\u0440\u043E\u043A\u0441\u0438\u0434 \u043D\u0430\u0442\u0440\u0438\u044F"
  _description: "<b>N<size=85%><b>a</b></size>OH</b>. \u0411\u0435\xAD\u043B\u043E\u0435
    \u0442\u0432\u0451\u0440\xAD\u0434\u043E\u0435 \u0432\u0435\xAD\u0449\u0435\u0441\u0442\xAD\u0432\u043E.
    \u0421\u0438\u043B\u044C\xAD\u043D\u043E \u0433\u0438\u0433\xAD\u0440\u043E\xAD\u0441\u043A\u043E\xAD\u043F\u0438\xAD\u0447\u0435\u043D,
    \u043D\u0430 \u0432\u043E\u0437\xAD\u0434\u0443\xAD\u0445\u0435 \xAB\u0440\u0430\u0441\xAD\u043F\u043B\u044B\xAD\u0432\u0430\xAD\u0435\u0442\xAD\u0441\u044F\xBB,
    \u0430\u043A\xAD\u0442\u0438\u0432\xAD\u043D\u043E \u043F\u043E\xAD\u0433\u043B\u043E\xAD\u0449\u0430\u044F
    \u043F\u0430\xAD\u0440\u044B \u0432\u043E\xAD\u0434\u044B \u0438 \u0443\u0433\xAD\u043B\u0435\xAD\u043A\u0438\u0441\xAD\u043B\u044B\u0439
    \u0433\u0430\u0437 \u0438\u0437 \u0432\u043E\u0437\xAD\u0434\u0443\xAD\u0445\u0430.
    \u0425\u043E\xAD\u0440\u043E\xAD\u0448\u043E \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u044F\xAD\u0435\u0442\xAD\u0441\u044F
    \u0432 \u0432\u043E\xAD\u0434\u0435, \u043F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u0432\u044B\xAD\u0434\u0435\xAD\u043B\u044F\xAD\u0435\u0442\xAD\u0441\u044F
    \u0431\u043E\u043B\u044C\xAD\u0448\u043E\u0435 \u043A\u043E\xAD\u043B\u0438\xAD\u0447\u0435\u0441\u0442\xAD\u0432\u043E
    \u0442\u0435\u043F\xAD\u043B\u043E\xAD\u0442\u044B. \u0420\u0430\u0441\xAD\u0442\u0432\u043E\u0440
    \u0435\u0434\xAD\u043A\u043E\xAD\u0433\u043E \u043D\u0430\u0442\xAD\u0440\u0430
    \u043C\u044B\xAD\u043B\u043E\u043A \u043D\u0430 \u043E\u0449\u0443\u043F\u044C."
