  _header: "\u0416\u0435\u043B\u0435\u0437\u043E"
  _description: "<b>F<size=85%><b>e</b></size></b>. \u0416\u0435\xAD\u043B\u0435\xAD\u0437\u043E
    \u0448\u0438\xAD\u0440\u043E\xAD\u043A\u043E \u0440\u0430\u0441\xAD\u043F\u0440\u043E\u0441\u0442\xAD\u0440\u0430\xAD\u043D\u0435\xAD\u043D\u043E
    \u0432 \u043F\u0440\u0438\xAD\u0440\u043E\xAD\u0434\u0435 \u2014 \u044D\u0442\u043E
    \u0441\u0430\xAD\u043C\u044B\u0439 \u0440\u0430\u0441\xAD\u043F\u0440\u043E\u0441\u0442\xAD\u0440\u0430\xAD\u043D\u0451\u043D\xAD\u043D\u044B\u0439
    \u043F\u043E\u0441\xAD\u043B\u0435 \u0430\u043B\u044E\xAD\u043C\u0438\xAD\u043D\u0438\u044F
    \u043C\u0435\xAD\u0442\u0430\u043B\u043B. \u0412 \u043F\u0440\u0438\xAD\u0440\u043E\xAD\u0434\u0435
    \u0436\u0435\xAD\u043B\u0435\xAD\u0437\u043E \u0432\u0441\u0442\u0440\u0435\xAD\u0447\u0430\xAD\u0435\u0442\xAD\u0441\u044F
    \u0432 \u0432\u0438\xAD\u0434\u0435 \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0439
    \u0441 \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0440\u043E\xAD\u0434\u043E\u043C
    \u0438\u043B\u0438 \u0441\u0435\xAD\u0440\u043E\u0439, \u0438\u043D\u043E\u0433\xAD\u0434\u0430
    \u0432\u0441\u0442\u0440\u0435\xAD\u0447\u0430\xAD\u0435\u0442\xAD\u0441\u044F
    \u0447\u0438\u0441\xAD\u0442\u043E\u0435 \u0436\u0435\xAD\u043B\u0435\xAD\u0437\u043E,
    \u043F\u043E\xAD\u043F\u0430\xAD\u0434\u0430\xAD\u044E\xAD\u0449\u0435\u0435
    \u043D\u0430 \u0417\u0435\u043C\xAD\u043B\u044E \u0441 \u043C\u0435\xAD\u0442\u0435\u043E\xAD\u0440\u0438\xAD\u0442\u0430\xAD\u043C\u0438."
