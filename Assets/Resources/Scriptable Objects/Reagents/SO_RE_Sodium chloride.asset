  _header: "\u0425\u043B\u043E\u0440\u0438\u0434 \u043D\u0430\u0442\u0440\u0438\u044F"
  _description: "<b>N<size=85%><b>a</b></size>Cl</b>. \u041D\u0430\u0442\xAD\u0440\u0438\xAD\u0435\xAD\u0432\u0430\u044F
    \u0441\u043E\u043B\u044C \u0445\u043B\u043E\xAD\u0440\u043E\xAD\u0432\u043E\xAD\u0434\u043E\xAD\u0440\u043E\u0434\xAD\u043D\u043E\u0439
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B. \u0412\u0445\u043E\xAD\u0434\u0438\u0442
    \u0432 \u0441\u043E\xAD\u0441\u0442\u0430\u0432 \u043F\u043E\xAD\u0432\u0430\xAD\u0440\u0435\u043D\xAD\u043D\u043E\u0439
    \u0441\u043E\xAD\u043B\u0438 \u043A\u0430\u043A \u0433\u043B\u0430\u0432\xAD\u043D\u044B\u0439
    \u043A\u043E\u043C\xAD\u043F\u043E\xAD\u043D\u0435\u043D\u0442, \u043F\u043E\xAD\u044D\u0442\u043E\xAD\u043C\u0443
    \u043F\u0440\u0438\xAD\u0432\u044B\u0447\xAD\u043D\u043E \u0435\u0435 \u043D\u0430\xAD\u0437\u0432\u0430\xAD\u043D\u0438\xAD\u0435\u043C
    \u0432 \u0431\u044B\xAD\u0442\u0443 \u0438 \u0438\u043C\u0435\xAD\u043D\u0443\xAD\u0435\u0442\xAD\u0441\u044F."
