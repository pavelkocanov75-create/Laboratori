  _description: "<b>K<size=60%><b>2</b></size>CO<size=60%><b>3</b></size></b>. \u0421\u0440\u0435\u0434\xAD\u043D\u044F\u044F
    \u0441\u043E\u043B\u044C \u043A\u0430\xAD\u043B\u0438\u044F \u0438 \u0443\u0433\u043E\u043B\u044C\xAD\u043D\u043E\u0439
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B. \u042D\u0442\u043E \u0431\u0435\xAD\u043B\u043E\u0435
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0432\u0435\xAD\u0449\u0435\u0441\u0442\xAD\u0432\u043E, \u0445\u043E\xAD\u0440\u043E\xAD\u0448\u043E
    \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0438\xAD\u043C\u043E\u0435
    \u0432 \u0432\u043E\xAD\u0434\u0435. \u041C\u0430\xAD\u043B\u043E\xAD\u0442\u043E\u043A\xAD\u0441\u0438\xAD\u0447\u0435\u043D,
    \u043E\u0442\xAD\u043D\u043E\xAD\u0441\u0438\u0442\xAD\u0441\u044F \u043A III
    \u043A\u043B\u0430\u0441\xAD\u0441\u0443 \u043E\u043F\u0430\u0441\xAD\u043D\u043E\u0441\xAD\u0442\u0438.
