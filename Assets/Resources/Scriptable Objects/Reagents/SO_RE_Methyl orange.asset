  _header: "\u041C\u0435\u0442\u0438\u043B\u043E\u0432\u044B\u0439 \u043E\u0440\u0430\u043D\u0436\u0435\u0432\u044B\u0439"
  _description: "\u041A\u0438\u0441\xAD\u043B\u043E\u0442\xAD\u043D\u043E-\u043E\u0441\xAD\u043D\u043E\u0432\xAD\u043D\u044B\u0439
    \u0438\u043D\xAD\u0434\u0438\xAD\u043A\u0430\xAD\u0442\u043E\u0440, \u0441\u0438\u043D\xAD\u0442\u0435\xAD\u0442\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0438\u0439
    \u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0438\u0439
    \u043A\u0440\u0430\xAD\u0441\u0438\xAD\u0442\u0435\u043B\u044C \u0438\u0437 \u0433\u0440\u0443\u043F\xAD\u043F\u044B
    \u0430\u0437\u043E\u043A\xAD\u0440\u0430\xAD\u0441\u0438\xAD\u0442\u0435\xAD\u043B\u0435\u0439,
    \u044F\u0432\xAD\u043B\u044F\xAD\u0435\u0442\xAD\u0441\u044F \u0441\u043E\xAD\u043B\u044C\u044E
    \u043D\u0430\u0442\xAD\u0440\u0438\u044F."
