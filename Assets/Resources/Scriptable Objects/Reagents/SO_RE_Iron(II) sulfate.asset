  _header: "\u0421\u0443\u043B\u044C\u0444\u0430\u0442 \u0436\u0435\u043B\u0435\u0437\u0430
    (II)"
  _description: "<b>F<size=85%><b>e</b></size>SO<size=60%><b>4</b></size></b>. \u041D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0435, \u0436\u0435\xAD\u043B\u0435\u0437\xAD\u043D\u0430\u044F
    \u0441\u043E\u043B\u044C \u0441\u0435\u0440\xAD\u043D\u043E\u0439 \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B.
    \u041D\u0435\xAD\u043B\u0435\xAD\u0442\u0443\u0447, \u043D\u0435 \u0438\u043C\u0435\xAD\u0435\u0442
    \u0437\u0430\xAD\u043F\u0430\xAD\u0445\u0430. \u0411\u0435\u0437\xAD\u0432\u043E\u0434\xAD\u043D\u043E\u0435
    \u0432\u0435\xAD\u0449\u0435\u0441\u0442\xAD\u0432\u043E \u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u043E\u0435,
    \u043D\u0435\xAD\u043F\u0440\u043E\xAD\u0437\u0440\u0430\u0447\xAD\u043D\u043E\u0435,
    \u043E\u0447\u0435\u043D\u044C \u0433\u0438\u0433\xAD\u0440\u043E\xAD\u0441\u043A\u043E\xAD\u043F\u0438\u0447\xAD\u043D\u043E\u0435."
