  m_Name: SO_RE_Aluminium chloride
  m_EditorClassIdentifier: 
  _header: "\u0425\u043B\u043E\u0440\u0438\u0434 \u0430\u043B\u044E\u043C\u0438\u043D\u0438\u044F"
  _description: "<b>AlCl<size=60%><b>3</b></size></b>. \u041D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0435, \u0441\u043E\u043B\u044C
    \u0430\u043B\u044E\xAD\u043C\u0438\xAD\u043D\u0438\u044F \u0438 \u0441\u043E\xAD\u043B\u044F\xAD\u043D\u043E\u0439
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B. \u0425\u043E\xAD\u0440\u043E\xAD\u0448\u043E
    \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0438\u043C \u0432 \u0432\u043E\xAD\u0434\u0435
    (44,38 \u0433 \u0432 100 \u0433 H<size=60%><b>2</b></size>O \u043F\u0440\u0438
    25 \xB0C). \u0418\u0437 \u0432\u043E\u0434\xAD\u043D\u044B\u0445 \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u043E\u0432
    \u0432\u044B\xAD\u043F\u0430\xAD\u0434\u0430\xAD\u0435\u0442 \u0432 \u0432\u0438\xAD\u0434\u0435
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u043E\xAD\u0433\u0438\u0434\xAD\u0440\u0430\xAD\u0442\u0430
    - \u0436\u0435\u043B\xAD\u0442\u043E\xAD\u0432\u0430\xAD\u0442\u043E-\u0431\u0435\xAD\u043B\u044B\u0435
    \u0440\u0430\u0441\xAD\u043F\u043B\u044B\xAD\u0432\u0430\xAD\u044E\xAD\u0449\u0438\xAD\u0435\xAD\u0441\u044F
    \u043D\u0430 \u0432\u043E\u0437\xAD\u0434\u0443\xAD\u0445\u0435 \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u044B.
    \u0425\u043E\xAD\u0440\u043E\xAD\u0448\u043E \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0438\u043C
    \u0432\u043E \u043C\u043D\u043E\xAD\u0433\u0438\u0445 \u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0438\u0445
    \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\xAD\u044F\u0445.
    \u041F\u0440\u0430\u043A\xAD\u0442\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0438
    \u043D\u0435 \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u044F\xAD\u0435\u0442\xAD\u0441\u044F
    \u0432 \u0431\u0435\u043D\xAD\u0437\u043E\xAD\u043B\u0435 \u0438 \u0442\u043E\xAD\u043B\u0443\xAD\u043E\u043B\u0435."
