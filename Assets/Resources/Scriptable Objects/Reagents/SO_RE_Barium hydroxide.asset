  _header: "\u0413\u0438\u0434\u0440\u043E\u043A\u0441\u0438\u0434 \u0431\u0430\u0440\u0438\u044F"
  _description: "<b>B<size=85%><b>a</b></size>(OH)<size=60%><b>2</b></size></b>.
    \u0425\u0438\xAD\u043C\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435 \u043D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0435, \u043F\u0440\u043E\xAD\u044F\u0432\xAD\u043B\u044F\xAD\u044E\xAD\u0449\u0435\u0435
    \u0441\u0438\u043B\u044C\xAD\u043D\u044B\u0435 \u043E\u0441\xAD\u043D\u043E\u0432\xAD\u043D\u044B\u0435
    \u0441\u0432\u043E\u0439\u0441\u0442\xAD\u0432\u0430. \u041D\u0430\xAD\u0441\u044B\xAD\u0449\u0435\u043D\xAD\u043D\u044B\u0439
    \u0432\u043E\u0434\xAD\u043D\u044B\u0439 \u0440\u0430\u0441\xAD\u0442\u0432\u043E\u0440
    \u0433\u0438\u0434\xAD\u0440\u043E\u043A\xAD\u0441\u0438\xAD\u0434\u0430 \u0431\u0430\xAD\u0440\u0438\u044F
    \u043D\u0430\xAD\u0437\u044B\xAD\u0432\u0430\xAD\u0435\u0442\xAD\u0441\u044F
    \xAB\u0431\u0430\xAD\u0440\u0438\xAD\u0442\u043E\xAD\u0432\u043E\u0439 \u0432\u043E\xAD\u0434\u043E\u0439\xBB.
    \u0415\u0434\xAD\u043A\u0438\u0439, \u044F\u0434\u043E\xAD\u0432\u0438\xAD\u0442\u044B\u0439."
