  _header: "\u0421\u0443\u043B\u044C\u0444\u0430\u0442 \u0430\u043B\u044E\u043C\u0438\u043D\u0438\u044F"
  _description: "<b>Al(SO<size=60%><b>4</b></size>)<size=60%><b>3</b></size></b>.
    \u0421\u043B\u043E\u0436\xAD\u043D\u043E\u0435 \u043D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0435, \u0441\u043E\u043B\u044C
    \u0430\u043B\u044E\xAD\u043C\u0438\xAD\u043D\u0438\u044F \u0438 \u0441\u0435\u0440\xAD\u043D\u043E\u0439
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B. \u0412\u044B\xAD\u0433\u043B\u044F\xAD\u0434\u0438\u0442
    \u043A\u0430\u043A \u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u044B\u0435
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u044B, \u043C\u043E\xAD\u0436\u0435\u0442
    \u043E\u0431\xAD\u0440\u0430\xAD\u0437\u043E\xAD\u0432\u044B\xAD\u0432\u0430\u0442\u044C
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u043E\xAD\u0433\u0438\u0434\xAD\u0440\u0430\xAD\u0442\u044B
    \u0441 \u0440\u0430\u0437\xAD\u043B\u0438\u0447\xAD\u043D\u044B\u043C \u0441\u043E\xAD\u0434\u0435\u0440\xAD\u0436\u0430\xAD\u043D\u0438\xAD\u0435\u043C
    \u0432\u043E\xAD\u0434\u044B."
