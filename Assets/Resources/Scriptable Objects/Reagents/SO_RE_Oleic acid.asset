  m_Name: SO_RE_Oleic acid
  m_EditorClassIdentifier: 
  _header: "\u041E\u043B\u0435\u0438\u043D\u043E\u0432\u0430\u044F \u043A\u0438\u0441\u043B\u043E\u0442\u0430"
  _description: "<b>C<size=60%><b>18</b></size>H<size=60%><b>34</b></size>O<size=60%><b>2</b></size></b>.
    \u041E\u0434\xAD\u043D\u0430 \u0438\u0437 \u0433\u043B\u0430\u0432\xAD\u043D\u0435\u0439\xAD\u0448\u0438\u0445
    \u0436\u0438\u0440\xAD\u043D\u044B\u0445 \u043A\u0438\u0441\xAD\u043B\u043E\u0442,
    \u0431\u0435\u0437 \u043A\u043E\xAD\u0442\u043E\xAD\u0440\u044B\u0445 \u0441\u0442\u0430\xAD\u043D\u043E\xAD\u0432\u0438\u0442\xAD\u0441\u044F
    \u043D\u0435\xAD\u0432\u043E\u0437\xAD\u043C\u043E\xAD\u0436\u0435\u043D \u043F\u0440\u0430\xAD\u0432\u0438\u043B\u044C\xAD\u043D\u044B\u0439
    \u043C\u0435\xAD\u0442\u0430\xAD\u0431\u043E\xAD\u043B\u0438\u0437\u043C, \u0442\u043E
    \u0435\u0441\u0442\u044C \u043E\u0431\xAD\u043C\u0435\u043D \u0432\u0435\xAD\u0449\u0435\u0441\u0442\u0432
    \u0432 \u0447\u0435\xAD\u043B\u043E\xAD\u0432\u0435\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u043C
    \u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\u0437\xAD\u043C\u0435, \u0432\u044B\u0441\xAD\u0448\u0430\u044F
    \u043C\u043E\xAD\u043D\u043E\xAD\u043D\u0435\xAD\u043D\u0430\xAD\u0441\u044B\xAD\u0449\u0435\u043D\xAD\u043D\u0430\u044F
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430 \u0436\u0438\xAD\u0440\u043E\u0432,
    \u0432\u0445\u043E\xAD\u0434\u0438\u0442 \u0432 \u0441\u043E\xAD\u0441\u0442\u0430\u0432
    \u043B\u0438\xAD\u043F\u0438\xAD\u0434\u043E\u0432. \u041E\u043B\u0435\xAD\u0438\xAD\u043D\u043E\xAD\u0432\u0430\u044F
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430 \u0444\u043E\u0440\xAD\u043C\u0443\xAD\u043B\u0430
    \u0421\u041D<size=60%><b>3</b></size>(\u0421\u041D<size=60%><b>2</b></size>)<size=60%><b>7</b></size>\u0421\u041D,
    \u0442\u0430\u043A\xAD\u0436\u0435 \u0421\u041D(\u0421\u041D<size=60%><b>2</b></size>)<size=60%><b>7</b></size>\u0421\u041E\u041E\u041D,
    \u0445\u0438\xAD\u043C\u0438\xAD\u043A\u0438 \u0435\u0449\u0435 \u043D\u0430\xAD\u0437\u044B\xAD\u0432\u0430\xAD\u044E\u0442
    \u0435\u0435 \u0446\u0438\u0441-9-\u043E\u043A\xAD\u0442\u0430\xAD\u0434\u0435\xAD\u0446\u0435\xAD\u043D\u043E\xAD\u0432\u0430\u044F
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430, \u043F\u0440\u0435\u0434\xAD\u0441\u0442\u0430\u0432\xAD\u043B\u044F\xAD\u0435\u0442
    \u0441\u043E\xAD\u0431\u043E\u0439 \u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u0443\u044E
    \u0432\u044F\u0437\xAD\u043A\u0443\u044E \u0436\u0438\u0434\xAD\u043A\u043E\u0441\u0442\u044C."
