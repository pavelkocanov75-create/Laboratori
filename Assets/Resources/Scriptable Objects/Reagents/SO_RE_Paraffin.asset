  _header: "\u041F\u0430\u0440\u0430\u0444\u0438\u043D"
  _description: "\u0412\u043E\xAD\u0441\u043A\u043E\xAD\u043F\u043E\xAD\u0434\u043E\u0431\xAD\u043D\u0430\u044F
    \u0441\u043C\u0435\u0441\u044C \u043F\u0440\u0435\xAD\u0434\u0435\u043B\u044C\xAD\u043D\u044B\u0445
    \u0443\u0433\xAD\u043B\u0435\xAD\u0432\u043E\xAD\u0434\u043E\xAD\u0440\u043E\xAD\u0434\u043E\u0432
    (\u0430\u043B\xAD\u043A\u0430\xAD\u043D\u043E\u0432) \u043F\u0440\u0435\xAD\u0438\u043C\u0443\xAD\u0449\u0435\u0441\u0442\xAD\u0432\u0435\u043D\xAD\u043D\u043E
    \u043D\u043E\u0440\xAD\u043C\u0430\u043B\u044C\xAD\u043D\u043E\xAD\u0433\u043E
    \u0441\u0442\u0440\u043E\xAD\u0435\xAD\u043D\u0438\u044F \u0441\u043E\xAD\u0441\u0442\u0430\xAD\u0432\u0430
    \u043E\u0442 \u0421<size=60%><b>18</b></size>\u041D<size=60%><b>38</b></size>
    (\u043E\u043A\xAD\u0442\u0430\xAD\u0434\u0435\xAD\u043A\u0430\u043D) \u0434\u043E
    \u0421<size=60%><b>35</b></size>\u041D<size=60%><b>72</b></size> (\u043F\u0435\u043D\xAD\u0442\u0430\u0442\xAD\u0440\u0438\xAD\u043E\xAD\u043A\u043E\u043D\xAD\u0442\u0430\u043D).
    \u041F\u043B\u043E\u0442\xAD\u043D\u043E\u0441\u0442\u044C \u2014 0,880-0,915
    \u0433/\u0441\u043C\xB3 (15 \xB0C)."
