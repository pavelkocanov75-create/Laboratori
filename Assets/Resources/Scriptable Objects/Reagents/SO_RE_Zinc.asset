  _header: "\u0426\u0438\u043D\u043A"
  _description: "<b>Z<size=85%><b>n</b></size></b>. \u0426\u0438\u043D\u043A \u043F\u0440\u043E\xAD\u044F\u0432\xAD\u043B\u044F\xAD\u0435\u0442
    \u0434\u043E\xAD\u0441\u0442\u0430\xAD\u0442\u043E\u0447\xAD\u043D\u043E \u0432\u044B\xAD\u0441\u043E\xAD\u043A\u0443\u044E
    \u0445\u0438\xAD\u043C\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0443\u044E \u0430\u043A\xAD\u0442\u0438\u0432\xAD\u043D\u043E\u0441\u0442\u044C,
    \u043E\u0431\xAD\u043B\u0430\xAD\u0434\u0430\xAD\u0435\u0442 \u0432\u044B\xAD\u0440\u0430\xAD\u0436\u0435\u043D\xAD\u043D\u044B\xAD\u043C\u0438
    \u0432\u043E\u0441\xAD\u0441\u0442\u0430\xAD\u043D\u043E\xAD\u0432\u0438\xAD\u0442\u0435\u043B\u044C\xAD\u043D\u044B\xAD\u043C\u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\xAD\u0432\u0430\xAD\u043C\u0438, \u043E\u0434\xAD\u043D\u0430\xAD\u043A\u043E
    \u043F\u043E \u0430\u043A\xAD\u0442\u0438\u0432\xAD\u043D\u043E\u0441\xAD\u0442\u0438
    \u0443\u0441\u0442\u0443\xAD\u043F\u0430\xAD\u0435\u0442 \u0449\u0451\u043B\u043E\u0447\xAD\u043D\u043E\xAD\u0437\u0435\xAD\u043C\u0435\u043B\u044C\xAD\u043D\u044B\u043C
    \u043C\u0435\xAD\u0442\u0430\u043B\xAD\u043B\u0430\u043C. \u041F\u0440\u0438
    \u043A\u043E\u043C\xAD\u043D\u0430\u0442\xAD\u043D\u043E\u0439 \u0442\u0435\u043C\xAD\u043F\u0435\xAD\u0440\u0430\xAD\u0442\u0443\xAD\u0440\u0435
    \u0432 \u0430\u0442\xAD\u043C\u043E\xAD\u0441\u0444\u0435\xAD\u0440\u0435 \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0440\u043E\xAD\u0434\u0430
    \u0446\u0438\u043D\u043A \u0442\u0443\u0441\u043A\xAD\u043D\u0435\xAD\u0435\u0442,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043F\u043E\xAD\u043A\u0440\u044B\xAD\u0432\u0430\xAD\u0435\u0442\xAD\u0441\u044F
    \u043E\u043A\xAD\u0441\u0438\u0434\xAD\u043D\u043E\u0439 \u043F\u043B\u0435\u043D\xAD\u043A\u043E\u0439."
