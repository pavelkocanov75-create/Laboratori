  _header: "\u0412\u043E\u0434\u0430"
  _description: "<b>H<size=60%><b>2</b></size>O</b>. \u0411\u0438\xAD\u043D\u0430\u0440\xAD\u043D\u043E\u0435
    \u043D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0435, \u043C\u043E\xAD\u043B\u0435\xAD\u043A\u0443\xAD\u043B\u0430
    \u043A\u043E\xAD\u0442\u043E\xAD\u0440\u043E\xAD\u0433\u043E \u0441\u043E\xAD\u0441\u0442\u043E\xAD\u0438\u0442
    \u0438\u0437 \u0434\u0432\u0443\u0445 \u0430\u0442\u043E\xAD\u043C\u043E\u0432
    \u0432\u043E\xAD\u0434\u043E\xAD\u0440\u043E\xAD\u0434\u0430 \u0438 \u043E\u0434\xAD\u043D\u043E\xAD\u0433\u043E
    \u2014 \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0440\u043E\xAD\u0434\u0430, \u043A\u043E\xAD\u0442\u043E\xAD\u0440\u044B\u0435
    \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u044B \u043C\u0435\u0436\xAD\u0434\u0443
    \u0441\u043E\xAD\u0431\u043E\u0439 \u043A\u043E\xAD\u0432\u0430\xAD\u043B\u0435\u043D\u0442\xAD\u043D\u043E\u0439
    \u0441\u0432\u044F\xAD\u0437\u044C\u044E."
