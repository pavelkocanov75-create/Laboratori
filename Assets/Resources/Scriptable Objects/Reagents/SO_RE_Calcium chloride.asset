  _header: "\u0425\u043B\u043E\u0440\u0438\u0434 \u043A\u0430\u043B\u044C\u0446\u0438\u044F"
  _description: "<b>C<size=85%><b>a</b></size>Cl<size=60%><b>2</b></size></b>. \u0425\u0438\xAD\u043C\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u043D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0432\u0435\xAD\u0449\u0435\u0441\u0442\xAD\u0432\u043E; \u043A\u0430\u043B\u044C\xAD\u0446\u0438\xAD\u0435\xAD\u0432\u0430\u044F
    \u0441\u043E\u043B\u044C \u0441\u043E\xAD\u043B\u044F\xAD\u043D\u043E\u0439 \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B.
    \u041D\u0435 \u044F\u0434\u043E\xAD\u0432\u0438\u0442, \u0437\u0430\xAD\u0440\u0435\xAD\u0433\u0438\u0441\u0442\xAD\u0440\u0438\xAD\u0440\u043E\xAD\u0432\u0430\u043D
    \u0432 \u043A\u0430\xAD\u0447\u0435\u0441\u0442\xAD\u0432\u0435 \u043F\u0438\xAD\u0449\u0435\xAD\u0432\u043E\u0439
    \u0434\u043E\xAD\u0431\u0430\u0432\xAD\u043A\u0438 E509. \u041F\u0440\u0438\xAD\u0432\u0435\xAD\u0434\u0435\xAD\u043D\u044B
    \u0434\u0430\u043D\xAD\u043D\u044B\u0435 \u0434\u043B\u044F \u0441\u0442\u0430\u043D\xAD\u0434\u0430\u0440\u0442\xAD\u043D\u044B\u0445
    \u0443\u0441\u043B\u043E\xAD\u0432\u0438\u0439 (25 \xB0C, 100 \u043A\u041F\u0430),
    \u0435\u0441\u043B\u0438 \u043D\u0435 \u0443\u043A\u0430\xAD\u0437\u0430\xAD\u043D\u043E
    \u0438\u043D\u043E\u0435."
