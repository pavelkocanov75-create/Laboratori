  _header: "\u041A\u0430\u0440\u0431\u043E\u043D\u0430\u0442 \u043A\u0430\u043B\u044C\u0446\u0438\u044F"
  _description: "<b>C<size=85%><b>a</b></size>CO<size=60%><b>3</b></size></b>. \u041D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0445\u0438\xAD\u043C\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435 \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0435,
    \u0441\u043E\u043B\u044C \u0443\u0433\u043E\u043B\u044C\xAD\u043D\u043E\u0439
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B \u0438 \u043A\u0430\u043B\u044C\xAD\u0446\u0438\u044F.
    \u0412\u0441\u0442\u0440\u0435\xAD\u0447\u0430\xAD\u0435\u0442\xAD\u0441\u044F
    \u0432 \u0432\u0438\xAD\u0434\u0435 \u043C\u043D\u043E\xAD\u0433\u043E\xAD\u0447\u0438\u0441\xAD\u043B\u0435\u043D\xAD\u043D\u044B\u0445
    \u043C\u0438\xAD\u043D\u0435\xAD\u0440\u0430\xAD\u043B\u043E\u0432, \u043D\u0430\xAD\u043F\u0440\u0438\xAD\u043C\u0435\u0440,
    \u043A\u0430\u043B\u044C\xAD\u0446\u0438\xAD\u0442\u0430, \u0430\u0440\u0430\xAD\u0433\u043E\xAD\u043D\u0438\xAD\u0442\u0430
    \u0438 \u0432\u0430\xAD\u0442\u0435\xAD\u0440\u0438\xAD\u0442\u0430, \u044F\u0432\xAD\u043B\u044F\xAD\u0435\u0442\xAD\u0441\u044F
    \u0433\u043B\u0430\u0432\xAD\u043D\u043E\u0439 \u0441\u043E\xAD\u0441\u0442\u0430\u0432\xAD\u043D\u043E\u0439
    \u0447\u0430\u0441\u0442\u044C\u044E \u0438\u0437\xAD\u0432\u0435\u0441\u0442\xAD\u043D\u044F\xAD\u043A\u0430,
    \u043C\u0440\u0430\xAD\u043C\u043E\xAD\u0440\u0430, \u043C\u0435\xAD\u043B\u0430,
    \u0432\u0445\u043E\xAD\u0434\u0438\u0442 \u0432 \u0441\u043E\xAD\u0441\u0442\u0430\u0432
    \u0441\u043A\u043E\u0440\xAD\u043B\u0443\xAD\u043F\u044B \u044F\u0438\u0446 \u043F\u0442\u0438\u0446
    \u0438 \u043F\u0440\u0435\xAD\u0441\u043C\u044B\xAD\u043A\u0430\xAD\u044E\xAD\u0449\u0438\u0445\xAD\u0441\u044F,
    \u0430 \u0442\u0430\u043A\xAD\u0436\u0435 \u0432 \u0441\u043E\xAD\u0441\u0442\u0430\u0432
    \u0440\u0430\xAD\u043A\u043E\xAD\u0432\u0438\u043D \u043C\u043E\u043B\xAD\u043B\u044E\u0441\xAD\u043A\u043E\u0432
    \u0438 \u043D\u0435\xAD\u043A\u043E\xAD\u0442\u043E\xAD\u0440\u044B\u0445 \u0434\u0440\u0443\xAD\u0433\u0438\u0445
    \u0431\u0435\u0441\xAD\u043F\u043E\u0437\u0432\u043E\xAD\u043D\u043E\u0447\xAD\u043D\u044B\u0445."
