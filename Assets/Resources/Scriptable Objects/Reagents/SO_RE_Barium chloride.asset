  _header: "\u0425\u043B\u043E\u0440\u0438\u0434 \u0431\u0430\u0440\u0438\u044F"
  _description: "<b>B<size=85%><b>a</b></size>Cl<size=60%><b>2</b></size></b>. \u041D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0432\u0435\xAD\u0449\u0435\u0441\u0442\xAD\u0432\u043E, \u043A\u043E\xAD\u0442\u043E\xAD\u0440\u043E\u0435
    \u043C\u043E\u0436\xAD\u043D\u043E \u0440\u0430\u0441\xAD\u0441\u043C\u0430\u0442\xAD\u0440\u0438\xAD\u0432\u0430\u0442\u044C
    \u043A\u0430\u043A \u0441\u043E\u043B\u044C \u0441\u043E\xAD\u043B\u044F\xAD\u043D\u043E\u0439
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B. \u0421 \u0442\u043E\u0447\xAD\u043A\u0438
    \u0437\u0440\u0435\xAD\u043D\u0438\u044F \u0445\u0438\xAD\u043C\u0438\u0438 \u2014
    \u0431\u0438\xAD\u043D\u0430\u0440\xAD\u043D\u043E\u0435 \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0435.
    \u041F\u043E\xAD\u043B\u0443\xAD\u0447\u0430\xAD\u044E\u0442 \u0442\u0435\u0440\xAD\u043C\u043E\xAD\u0445\u0438\xAD\u043C\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0438\u043C
    \u0441\u043F\u043E\xAD\u0441\u043E\xAD\u0431\u043E\u043C \u0438\u0437 \u043A\u043E\u043D\xAD\u0446\u0435\u043D\u0442\xAD\u0440\u0430\xAD\u0442\u0430
