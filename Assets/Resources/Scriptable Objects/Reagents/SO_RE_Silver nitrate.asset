  _header: "\u041D\u0438\u0442\u0440\u0430\u0442 \u0441\u0435\u0440\u0435\u0431\u0440\u0430"
  _description: "<b>A<size=85%><b>g</b></size>(NO<size=60%><b>3</b></size>)<size=60%><b>2</b></size></b>.
    \u041D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0435, \u0441\u043E\u043B\u044C
    \u043C\u0435\xAD\u0442\u0430\u043B\xAD\u043B\u0430 \u0441\u0435\xAD\u0440\u0435\u0431\xAD\u0440\u0430
    \u0438 \u0430\u0437\u043E\u0442\xAD\u043D\u043E\u0439 \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B,
    \u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u044B\u0435 \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u044B,
    \u0440\u0430\u0437\xAD\u043B\u0430\xAD\u0433\u0430\xAD\u0435\u0442\xAD\u0441\u044F
    \u0432\u043E\xAD\u0434\u043E\u0439."
