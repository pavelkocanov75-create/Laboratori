  _header: "\u0423\u043A\u0441\u0443\u0441\u043D\u0430\u044F \u043A\u0438\u0441\u043B\u043E\u0442\u0430"
  _description: "<b>CH<size=60%><b>3</b></size>COOH</b>. \u0421\u043B\u0430\xAD\u0431\u0430\u044F
    \u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0430\u044F
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430, \u043E\u0442\xAD\u043D\u043E\xAD\u0441\u044F\xAD\u0449\u0430\xAD\u044F\xAD\u0441\u044F
    \u043A \u043A\u043B\u0430\u0441\xAD\u0441\u0443 \u043F\u0440\u0435\xAD\u0434\u0435\u043B\u044C\xAD\u043D\u044B\u0445
    \u043A\u0430\u0440\xAD\u0431\u043E\xAD\u043D\u043E\xAD\u0432\u044B\u0445 \u043A\u0438\u0441\xAD\u043B\u043E\u0442.
    \u041F\u0440\u0438 \u0441\u0442\u0430\u043D\xAD\u0434\u0430\u0440\u0442\xAD\u043D\u044B\u0445
    \u0443\u0441\u043B\u043E\xAD\u0432\u0438\xAD\u044F\u0445 \u0443\u043A\xAD\u0441\u0443\u0441\xAD\u043D\u0430\u044F
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430 \u2014 \u044D\u0442\u043E
    \u043E\u0434\xAD\u043D\u043E\xAD\u043E\u0441\xAD\u043D\u043E\u0432\xAD\u043D\u0430\u044F
    \u043A\u0430\u0440\xAD\u0431\u043E\xAD\u043D\u043E\xAD\u0432\u0430\u044F \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430,
    \u043F\u0440\u0435\u0434\xAD\u0441\u0442\u0430\u0432\xAD\u043B\u044F\xAD\u044E\xAD\u0449\u0430\u044F
    \u0441\u043E\xAD\u0431\u043E\u0439 \u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u0443\u044E
    \u0436\u0438\u0434\xAD\u043A\u043E\u0441\u0442\u044C \u0441 \u0445\u0430\xAD\u0440\u0430\u043A\xAD\u0442\u0435\u0440\xAD\u043D\u044B\u043C
    \u0440\u0435\u0437\xAD\u043A\u0438\u043C \u0437\u0430\xAD\u043F\u0430\xAD\u0445\u043E\u043C
    \u0438 \u043A\u0438\u0441\xAD\u043B\u044B\u043C \u0432\u043A\u0443\xAD\u0441\u043E\u043C."
