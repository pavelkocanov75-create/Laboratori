  m_Name: SO_RE_Ethanol
  m_EditorClassIdentifier: 
  _header: "\u042D\u0442\u0430\u043D\u043E\u043B"
  _description: "\u041E\u0442\xAD\u043D\u043E\xAD\u0441\u0438\u0442\xAD\u0441\u044F
    \u043A \u0445\u0438\xAD\u043C\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0438\u043C
    \u0430\u043A\xAD\u0442\u0438\u0432\xAD\u043D\u044B\u043C \u0440\u0435\xAD\u0430\xAD\u0433\u0435\u043D\xAD\u0442\u0430\u043C,
    \u043E\u0431\xAD\u043B\u0430\xAD\u0434\u0430\xAD\u044E\xAD\u0449\u0438\u0435
    \u043D\u0435\xAD\u043A\u043E\xAD\u0442\u043E\xAD\u0440\u044B\xAD\u043C\u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\xAD\u0432\u0430\xAD\u043C\u0438, \u043A\u043E\xAD\u0442\u043E\xAD\u0440\u044B\u0435
    \u0438\u043C\u0435\xAD\u044E\u0442\xAD\u0441\u044F \u0443 \u043A\u0438\u0441\xAD\u043B\u043E\u0442.
    \u041D\u043E \u0432 \u0431\u043E\xAD\u043B\u0435\u0435 \u0441\u043B\u0430\xAD\u0431\u043E\u0439
    \u0444\u043E\u0440\xAD\u043C\u0435. \u0412\u0441\u0435 \u044D\u0442\u043E \u043F\u043E\xAD\u0437\u0432\u043E\xAD\u043B\u044F\xAD\u0435\u0442
    \u0441\u043F\u0438\u0440\xAD\u0442\u0443 \u0432\u0437\u0430\xAD\u0438\xAD\u043C\u043E\xAD\u0434\u0435\u0439\u0441\u0442\xAD\u0432\u043E\xAD\u0432\u0430\u0442\u044C
    \u0441 \u0449\u0435\xAD\u043B\u043E\u0447\xAD\u043D\u043E\xAD\u0437\u0435\xAD\u043C\u0435\u043B\u044C\xAD\u043D\u044B\xAD\u043C\u0438
    \u043C\u0435\xAD\u0442\u0430\u043B\xAD\u043B\u0430\xAD\u043C\u0438 \u0438 \u0434\u0430\u043B\u044C\xAD\u043D\u0435\u0439\xAD\u0448\u0435\xAD\u043C\u0443
    \u043E\u0431\xAD\u0440\u0430\xAD\u0437\u043E\xAD\u0432\u0430\xAD\u043D\u0438\u044E
    \u044D\u0442\u0438\xAD\u043B\u0430\xAD\u0442\u043E\u0432. \u0415\u0441\u043B\u0438
    \u043F\u0440\u0438\xAD\u043C\u0435\xAD\u043D\u044F\u0442\u044C \u043E\u043F\u0440\u0435\xAD\u0434\u0435\xAD\u043B\u0435\u043D\xAD\u043D\u044B\u0435
    \u0443\u0441\u043B\u043E\xAD\u0432\u0438\u044F, \u0442\u043E \u0432 \u0440\u0435\xAD\u0430\u043A\xAD\u0446\u0438\u0438
    \u0441 \u043A\u0430\u0440\xAD\u0431\u043E\xAD\u043D\u043E\xAD\u0432\u044B\xAD\u043C\u0438
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430\xAD\u043C\u0438, \u0441\u043F\u0438\u0440\u0442
    \u0441\u043F\u043E\xAD\u0441\u043E\xAD\u0431\u0435\u043D \u043E\u0431\xAD\u0440\u0430\xAD\u0437\u043E\xAD\u0432\u0430\u0442\u044C
    \u043A\u0443\xAD\u0434\u0430 \u0431\u043E\xAD\u043B\u0435\u0435 \u0441\u043B\u043E\u0436\xAD\u043D\u044B\u0435
    \u044D\u0444\u0438\xAD\u0440\u044B \u2013 \u043E\u0442 \u0449\u0430\xAD\u0432\u0435\xAD\u043B\u0435\xAD\u0432\u043E\u0439
    \u0434\u043E \u0443\u043A\xAD\u0441\u0443\u0441\xAD\u043D\u043E\u0439 \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B."
  _sprite: {fileID: 21300000, guid: bba276033649b3d4aa8574d6f8703b16, type: 3}
