  _header: "\u0420\u043E\u0434\u0430\u043D\u0438\u0434 \u043A\u0430\u043B\u0438\u044F"
  _description: "<b>KSCN</b>. \u0418\u043C\u0435\xAD\u0435\u0442 \u0432\u0438\u0434
    \u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u044B\u0445 \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u043E\u0432,
    \u0440\u0430\u0441\xAD\u043F\u043B\u044B\xAD\u0432\u0430\xAD\u0435\u0442\xAD\u0441\u044F
    \u043D\u0430 \u0432\u043E\u0437\xAD\u0434\u0443\xAD\u0445\u0435 \u0438\u0437-\u0437\u0430
    \u0433\u0438\u0433\xAD\u0440\u043E\xAD\u0441\u043A\u043E\xAD\u043F\u0438\u0447\xAD\u043D\u043E\u0441\xAD\u0442\u0438.
    \u041F\u043B\u043E\u0442\xAD\u043D\u043E\u0441\u0442\u044C \u0441\u043E\xAD\u0441\u0442\u0430\u0432\xAD\u043B\u044F\xAD\u0435\u0442
    1.886 \u0433 /\u0441\u043C\xB3, \u043F\u043B\u0430\xAD\u0432\u0438\u0442\xAD\u0441\u044F
    \u043F\u0440\u0438 173,2 \xB0\u0421, \u043A\u0438\xAD\u043F\u0438\u0442 \u0441
    \u0440\u0430\u0437\xAD\u043B\u043E\xAD\u0436\u0435\xAD\u043D\u0438\xAD\u0435\u043C
    \u043F\u0440\u0438 500 \xB0\u0421. \u0425\u043E\xAD\u0440\u043E\xAD\u0448\u043E
    \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0438\u043C \u0432 \u0432\u043E\xAD\u0434\u0435,
    \u043F\u0440\u0438 \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0435\xAD\u043D\u0438\u0438
    \u043D\u0430\xAD\u0431\u043B\u044E\xAD\u0434\u0430\xAD\u0435\u0442\xAD\u0441\u044F
    \u0441\u0438\u043B\u044C\xAD\u043D\u043E\u0435 \u043E\u0445\u043B\u0430\u0436\xAD\u0434\u0435\xAD\u043D\u0438\u0435
    \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0430, \u0442\u0430\u043A\xAD\u0436\u0435
    \u043B\u0435\u0433\xAD\u043A\u043E \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u044F\xAD\u0435\u0442\xAD\u0441\u044F
    \u0432 \u044D\u0442\u0438\xAD\u043B\u043E\xAD\u0432\u043E\u043C \u0438 \u0430\u043C\u0438\xAD\u043B\u043E\xAD\u0432\u043E\u043C
    \u0441\u043F\u0438\u0440\xAD\u0442\u0430\u0445."
