  _header: "\u0421\u043F\u0438\u0440\u0442\u043E\u0432\u043E\u0439 \u0440\u0430\u0441\u0442\u0432\u043E\u0440
    \u0439\u043E\u0434\u0430"
  _description: "\u0420\u0430\u0441\xAD\u0442\u0432\u043E\u0440 100 \u043C\u043B
    \u0441\u043E\xAD\u0434\u0435\u0440\xAD\u0436\u0438\u0442\xAD\u0441\u044F \u0432
    \u043A\u0430\xAD\u0447\u0435\u0441\u0442\xAD\u0432\u0435 \u0434\u0435\u0439\u0441\u0442\xAD\u0432\u0443\xAD\u044E\xAD\u0449\u0435\xAD\u0433\u043E
    \u0432\u0435\xAD\u0449\u0435\u0441\u0442\xAD\u0432\u0430 \u0439\u043E\xAD\u0434\u0430
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\xAD\u0433\u043E
    \u2013 5 \u0433, \u0432 \u043A\u0430\xAD\u0447\u0435\u0441\u0442\xAD\u0432\u0435
    \u0432\u0441\u043F\u043E\xAD\u043C\u043E\xAD\u0433\u0430\xAD\u0442\u0435\u043B\u044C\xAD\u043D\u044B\u0445
    \u0432\u0435\xAD\u0449\u0435\u0441\u0442\u0432 \u043A\u0430\xAD\u043B\u0438\u0439
    \u0439\u043E\xAD\u0434\u0438\xAD\u0441\xAD\u0442\u044B\u0439, \u0441\u043F\u0438\u0440\u0442
    \u044D\u0442\u0438\xAD\u043B\u043E\xAD\u0432\u044B\u0439 (\u044D\u0442\u0430\xAD\u043D\u043E\u043B)
    \u0438 \u0432\u043E\xAD\u0434\u0430 \u043E\u0447\u0438\xAD\u0449\u0435\u043D\xAD\u043D\u0430\u044F
    1:1."
