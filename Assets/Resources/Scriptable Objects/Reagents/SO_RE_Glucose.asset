  _description: "<b>C<size=60%><b>6</b></size>H<size=60%><b>12</b></size>O<size=60%><b>6</b></size></b>.
    \u041E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0440\u043E\u0434\xAD\u0441\u043E\xAD\u0434\u0435\u0440\xAD\u0436\u0430\xAD\u0449\u0435\u0435
    \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0435 \u0441
    \u0448\u0435\u0441\u0442\u044C\u044E \u0430\u0442\u043E\xAD\u043C\u0430\xAD\u043C\u0438
    \u0443\u0433\xAD\u043B\u0435\xAD\u0440\u043E\xAD\u0434\u0430 \u043D\u0430\xAD\u0437\u044B\xAD\u0432\u0430\xAD\u0435\u0442\xAD\u0441\u044F
