    \u042D\u0442\u043E \u0443\u043D\u0438\xAD\u0432\u0435\u0440\xAD\u0441\u0430\u043B\u044C\xAD\u043D\u044B\u0439
    \u0438\u0441\xAD\u0442\u043E\u0447\xAD\u043D\u0438\u043A \u044D\u043D\u0435\u0440\xAD\u0433\u0438\u0438
