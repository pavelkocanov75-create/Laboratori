  _header: "\u0421\u0443\u043B\u044C\u0444\u0430\u0442 \u0446\u0438\u043D\u043A\u0430"
  _description: "<b>Z<size=85%><b>n</b></size>SO<size=60%><b>4</b></size></b>. \u0426\u0438\u043D\xAD\u043A\u043E\xAD\u0432\u0430\u044F
    \u0441\u043E\u043B\u044C \u0441\u0435\u0440\xAD\u043D\u043E\u0439 \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B,
    \u0432 \u0432\u0438\xAD\u0434\u0435 \u043F\u043E\xAD\u0440\u043E\u0448\xAD\u043A\u0430,
    \u0441\u043E\xAD\u0441\u0442\u043E\xAD\u044F\xAD\u0449\u0435\xAD\u0433\u043E
    \u0438\u0437 \u043F\u0440\u043E\xAD\u0437\u0440\u0430\u0447\xAD\u043D\u044B\u0445,
    \u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u044B\u0445 \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u043E\u0432
    \u0431\u0435\u0437 \u0437\u0430\xAD\u043F\u0430\xAD\u0445\u0430, \u043D\u043E
    \u0441 \u0440\u0435\u0437\xAD\u043A\u0438\u043C \u0438 \u0432\u044F\xAD\u0436\u0443\xAD\u0449\u0438\u043C
    \u0432\u043A\u0443\xAD\u0441\u043E\u043C."
