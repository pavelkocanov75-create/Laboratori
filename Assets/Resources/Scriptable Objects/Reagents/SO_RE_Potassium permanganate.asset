  m_Name: SO_RE_Potassium permanganate
  m_EditorClassIdentifier: 
  _header: "\u041F\u0435\u0440\u043C\u0430\u043D\u0433\u0430\u043D\u0430\u0442 \u043A\u0430\u043B\u0438\u044F"
  _description: "<b>KM<size=85%><b>n</b></size>O<size=60%><b>4</b></size></b>. \u041C\u0430\u0440\xAD\u0433\u0430\u043D\xAD\u0446\u043E\xAD\u0432\u043E\xAD\u043A\u0438\u0441\xAD\u043B\u044B\u0439
    \u043A\u0430\xAD\u043B\u0438\u0439, \u043A\u0430\xAD\u043B\u0438\xAD\u0435\xAD\u0432\u0430\u044F
    \u0441\u043E\u043B\u044C \u043C\u0430\u0440\xAD\u0433\u0430\u043D\xAD\u0446\u043E\xAD\u0432\u043E\u0439
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B. \u041F\u0440\u0435\u0434\xAD\u0441\u0442\u0430\u0432\xAD\u043B\u044F\xAD\u0435\u0442
    \u0441\u043E\xAD\u0431\u043E\u0439 \u0442\u0451\u043C\xAD\u043D\u043E-\u0444\u0438\xAD\u043E\xAD\u043B\u0435\xAD\u0442\u043E\xAD\u0432\u044B\u0435,
    \u043F\u043E\u0447\xAD\u0442\u0438 \u0447\u0451\u0440\xAD\u043D\u044B\u0435 \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u044B,
    \u043F\u0440\u0438 \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0435\xAD\u043D\u0438\u0438
    \u0432 \u0432\u043E\xAD\u0434\u0435 \u043E\u0431\xAD\u0440\u0430\xAD\u0437\u0443\xAD\u044E\xAD\u0449\u0438\u0435
    \u044F\u0440\xAD\u043A\u043E \u043E\u043A\u0440\u0430\xAD\u0448\u0435\u043D\xAD\u043D\u044B\u0439
    \u0440\u0430\u0441\xAD\u0442\u0432\u043E\u0440 \u0446\u0432\u0435\xAD\u0442\u0430
    \u0444\u0443\u043A\xAD\u0441\u0438\u0438."
