  _header: "\u0421\u0443\u043B\u044C\u0444\u0430\u0442 \u043C\u0430\u0433\u043D\u0438\u044F"
  _description: "<b>M<size=85%><b>g</b></size>SO<size=60%><b>4</b></size></b>. \u041D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0432\u0435\xAD\u0449\u0435\u0441\u0442\xAD\u0432\u043E, \u0441\u043E\u043B\u044C
    \u043C\u0435\xAD\u0442\u0430\u043B\xAD\u043B\u0430 \u043C\u0430\u0433\xAD\u043D\u0438\u044F
    \u0438 \u0441\u0435\u0440\xAD\u043D\u043E\u0439 \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B,
    \u0431\u0435\xAD\u043B\u044B\u0439 \u043F\u043E\xAD\u0440\u043E\xAD\u0448\u043E\u043A,
    \u043E\u0431\xAD\u0440\u0430\xAD\u0437\u0443\xAD\u0435\u0442 \u043D\u0435\xAD\u0441\u043A\u043E\u043B\u044C\xAD\u043A\u043E
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u043E\xAD\u0433\u0438\u0434\xAD\u0440\u0430\xAD\u0442\u043E\u0432.
    \u0412 \u043C\u0435\xAD\u0434\u0438\xAD\u0446\u0438\xAD\u043D\u0435 \u0438\u0441\xAD\u043F\u043E\u043B\u044C\xAD\u0437\u0443\xAD\u0435\u0442\xAD\u0441\u044F
    \u043F\u0440\u0438 \u043B\u0435\xAD\u0447\u0435\xAD\u043D\u0438\u0438 \u043E\u0436\u0438\xAD\u0440\u0435\xAD\u043D\u0438\u044F
    \u043A\u0430\u043A \u0441\u043E\xAD\u043B\u0435\xAD\u0432\u043E\u0435 \u0441\u043B\u0430\xAD\u0431\u0438\xAD\u0442\u0435\u043B\u044C\xAD\u043D\u043E\u0435,
    \u0434\u043B\u044F \u0434\u043E\xAD\u0441\u0442\u0438\xAD\u0436\u0435\xAD\u043D\u0438\u044F
    \u0442\u0430\u043A \u043D\u0430\xAD\u0437\u044B\xAD\u0432\u0430\xAD\u0435\xAD\u043C\u043E\xAD\u0433\u043E
    \u043C\u0430\u0433\xAD\u043D\u0438\xAD\u0435\xAD\u0432\u043E\xAD\u0433\u043E
    \u0441\u0442\u0440\u0435\u0441\xAD\u0441\u0430."
