  m_Name: SO_RE_Copper(II) oxide
  m_EditorClassIdentifier: 
  _header: "\u041E\u043A\u0441\u0438\u0434 \u043C\u0435\u0434\u0438 (II)"
  _description: "<b>C<size=85%><b>u</b></size>O</b>. \u041E\u043A\xAD\u0441\u0438\u0434
    \u0434\u0432\u0443\u0445\xAD\u0432\u0430\xAD\u043B\u0435\u043D\u0442\xAD\u043D\u043E\u0439
    \u043C\u0435\xAD\u0434\u0438. \u041A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u044B
    \u0447\u0451\u0440\xAD\u043D\u043E\xAD\u0433\u043E \u0446\u0432\u0435\xAD\u0442\u0430,
    \u0432 \u043E\u0431\u044B\u0447\xAD\u043D\u044B\u0445 \u0443\u0441\u043B\u043E\xAD\u0432\u0438\xAD\u044F\u0445
    \u0434\u043E\xAD\u0432\u043E\u043B\u044C\xAD\u043D\u043E \u0443\u0441\u0442\u043E\u0439\xAD\u0447\u0438\xAD\u0432\u044B\u0435,
    \u043F\u0440\u0430\u043A\xAD\u0442\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0438
    \u043D\u0435\xAD\u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0438\xAD\u043C\u044B\u0435
    \u0432 \u0432\u043E\xAD\u0434\u0435. \u0412 \u043F\u0440\u0438\xAD\u0440\u043E\xAD\u0434\u0435
    \u0432\u0441\u0442\u0440\u0435\xAD\u0447\u0430\xAD\u0435\u0442\xAD\u0441\u044F
    \u0432 \u0432\u0438\xAD\u0434\u0435 \u043C\u0438\xAD\u043D\u0435\xAD\u0440\u0430\xAD\u043B\u0430
    \u0442\u0435\xAD\u043D\u043E\xAD\u0440\u0438\xAD\u0442\u0430 (\u043C\u0435\xAD\u043B\u0430\xAD\u043A\u043E\xAD\u043D\u0438\xAD\u0442\u0430)
    \u0447\u0451\u0440\xAD\u043D\u043E\xAD\u0433\u043E \u0446\u0432\u0435\xAD\u0442\u0430."
  _sprite: {fileID: 21300000, guid: 2e6c2e279c96b38458f4a54374d067e4, type: 3}
