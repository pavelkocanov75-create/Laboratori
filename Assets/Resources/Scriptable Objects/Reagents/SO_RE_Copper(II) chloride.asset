  m_Name: SO_RE_Copper(II) chloride
  m_EditorClassIdentifier: 
  _header: "\u0425\u043B\u043E\u0440\u0438\u0434 \u043C\u0435\u0434\u0438 (II)"
  _description: "<b>C<size=85%><b>u</b></size>Cl<size=60%><b>4</b></size></b>. \u041D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0430\u044F
    \u0431\u0438\xAD\u043D\u0430\u0440\xAD\u043D\u0430\u044F \u043C\u0435\u0434\xAD\u043D\u0430\u044F
    \u0441\u043E\u043B\u044C \u0441\u043E\xAD\u043B\u044F\xAD\u043D\u043E\u0439 \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B
    (\u043C\u043E\xAD\u0436\u0435\u0442 \u0440\u0430\u0441\xAD\u0441\u043C\u0430\u0442\xAD\u0440\u0438\xAD\u0432\u0430\u0442\u044C\xAD\u0441\u044F
    \u043A\u0430\u043A \u043C\u0435\u0434\xAD\u043D\u044B\u0439 \u0433\u0430\xAD\u043B\u043E\xAD\u0433\u0435\xAD\u043D\u0438\u0434).
    \u041F\u0440\u0435\u0434\xAD\u0441\u0442\u0430\u0432\xAD\u043B\u044F\xAD\u0435\u0442
    \u0441\u043E\xAD\u0431\u043E\u0439 \u0436\u0451\u043B\xAD\u0442\u043E-\u0431\u0443\xAD\u0440\u044B\u0435
    (\u043F\u043E \u043D\u0435\xAD\u043A\u043E\xAD\u0442\u043E\xAD\u0440\u044B\u043C
    \u0434\u0430\u043D\xAD\u043D\u044B\u043C \u2014 \u0442\u0451\u043C\xAD\u043D\u043E-\u043A\u043E\xAD\u0440\u0438\u0447\xAD\u043D\u0435\xAD\u0432\u044B\u0435)
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u044B \u0441 \u043C\u043E\xAD\u043D\u043E\u043A\xAD\u043B\u0438\u043D\xAD\u043D\u043E\u0439
    \u0440\u0435\xAD\u0448\u0435\u0442\xAD\u043A\u043E\u0439, \u043F\u0440\u043E\u0441\u0442\xAD\u0440\u0430\u043D\u0441\u0442\xAD\u0432\u0435\u043D\xAD\u043D\u0430\u044F
    \u0433\u0440\u0443\u043F\xAD\u043F\u0430."
  _sprite: {fileID: 21300000, guid: eeb13bb717ffeaa44a2de547d8702f79, type: 3}
