  _header: "\u041A\u0430\u0440\u0431\u043E\u043D\u0430\u0442 \u043D\u0430\u0442\u0440\u0438\u044F"
  _description: "<b>N<size=85%><b>a</b></size><size=60%><b>2</b></size>CO<size=60%><b>3</b></size></b>.
    \u041D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0435, \u043D\u0430\u0442\xAD\u0440\u0438\xAD\u0435\xAD\u0432\u0430\u044F
    \u0441\u043E\u043B\u044C \u0443\u0433\u043E\u043B\u044C\xAD\u043D\u043E\u0439
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B. \u0411\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u044B\u0435
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u044B \u0438\u043B\u0438
    \u0431\u0435\xAD\u043B\u044B\u0439 \u043F\u043E\xAD\u0440\u043E\xAD\u0448\u043E\u043A,
    \u0445\u043E\xAD\u0440\u043E\xAD\u0448\u043E \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0438\xAD\u043C\u044B\u0439
    \u0432 \u0432\u043E\xAD\u0434\u0435."
