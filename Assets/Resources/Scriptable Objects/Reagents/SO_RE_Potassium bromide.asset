  _header: "\u0411\u0440\u043E\u043C\u0438\u0441\u0442\u044B\u0439 \u043A\u0430\u043B\u0438\u0439"
  _description: "<b>KB<size=85%><b>r</b></size></b>. \u041D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\u0435
    \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0435, \u043A\u0430\xAD\u043B\u0438\xAD\u0435\xAD\u0432\u0430\u044F
    \u0441\u043E\u043B\u044C \u0431\u0440\u043E\xAD\u043C\u043E\xAD\u0432\u043E\xAD\u0434\u043E\xAD\u0440\u043E\u0434\xAD\u043D\u043E\u0439
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u044B. \u0418\u043C\u0435\xAD\u0435\u0442
    \u0432\u0438\u0434 \u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u043E\xAD\u0433\u043E
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\xAD\u0433\u043E
    \u0432\u0435\xAD\u0449\u0435\u0441\u0442\xAD\u0432\u0430."
