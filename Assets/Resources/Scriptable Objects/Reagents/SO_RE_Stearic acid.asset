  m_Name: SO_RE_Stearic acid
  m_EditorClassIdentifier: 
  _header: "\u0421\u0442\u0435\u0430\u0440\u0438\u043D\u043E\u0432\u0430\u044F \u043A\u0438\u0441\u043B\u043E\u0442\u0430"
  _description: "<b>\u0421<size=60%><b>17</b></size>\u041D<size=60%><b>35</b></size>COOH</b>.
    \u0421\u0442\u0435\xAD\u0430\xAD\u0440\u0438\xAD\u043D\u043E\xAD\u0432\u0430\u044F
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430 (\u0442\u0440\u0438\xAD\u0432\u0438\xAD\u0430\u043B\u044C\xAD\u043D\u043E\u0435
    \u043D\u0430\xAD\u0437\u0432\u0430\xAD\u043D\u0438\u0435), \u0446\u0435\xAD\u0442\u0438\xAD\u043B\u0443\u043A\xAD\u0441\u0443\u0441\xAD\u043D\u0430\u044F
    \u0438\u043B\u0438 \u043D-\u043E\u043A\xAD\u0442\u0430\xAD\u0434\u0435\xAD\u043A\u0430\xAD\u043D\u043E\xAD\u0432\u0430\u044F
    \u043A\u0438\u0441\xAD\u043B\u043E\u0442, \u043E\u0434\xAD\u043D\u043E\xAD\u043E\u0441\xAD\u043D\u043E\u0432\xAD\u043D\u0430\u044F
    \u043A\u0430\u0440\xAD\u0431\u043E\xAD\u043D\u043E\xAD\u0432\u0430\u044F \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430
    \u0430\u043B\u0438\xAD\u0444\u0430\xAD\u0442\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u043E\xAD\u0433\u043E
    \u0440\u044F\xAD\u0434\u0430, \u0438\u043C\u0435\xAD\u044E\xAD\u0449\u0430\u044F
    \u043F\u0440\u0438 \u043A\u043E\u043C\xAD\u043D\u0430\u0442\xAD\u043D\u043E\u0439
    \u0442\u0435\u043C\xAD\u043F\u0435\xAD\u0440\u0430\xAD\u0442\u0443\xAD\u0440\u0435
    \u0432\u0438\u0434 \u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u044B\u0445
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u043E\u0432, \u0445\u043E\xAD\u0440\u043E\xAD\u0448\u043E
    \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0438\xAD\u043C\u044B\u0445
    \u0432 \u0434\u0438\xAD\u044D\u0442\u0438\xAD\u043B\u043E\xAD\u0432\u043E\u043C
    \u044D\u0444\u0438\xAD\u0440\u0435 \u0438 \u043D\u0435 \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0438\xAD\u043C\u044B\u0445
    \u0432 \u0432\u043E\xAD\u0434\u0435. \u0421\u0442\u0435\xAD\u0430\xAD\u0440\u0438\xAD\u043D\u043E\xAD\u0432\u0430\u044F
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430 \u2014 \u044D\u0442\u043E
    \u043D\u0430\xAD\u0441\u044B\xAD\u0449\u0435\u043D\xAD\u043D\u0430\u044F \u0436\u0438\u0440\xAD\u043D\u0430\u044F
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430, \u043E\u0434\xAD\u043D\u0430
    \u0438\u0437 \u043D\u0430\u0438\u0431\u043E\xAD\u043B\u0435\u0435 \u0440\u0430\u0441\xAD\u043F\u0440\u043E\u0441\u0442\xAD\u0440\u0430\xAD\u043D\u0451\u043D\xAD\u043D\u044B\u0445
    \u0432 \u043F\u0440\u0438\xAD\u0440\u043E\xAD\u0434\u0435 \u0436\u0438\u0440\xAD\u043D\u044B\u0445
    \u043A\u0438\u0441\xAD\u043B\u043E\u0442."
