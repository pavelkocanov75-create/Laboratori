  _header: "\u0424\u043E\u0441\u0444\u043E\u0440\u043D\u0430\u044F \u043A\u0438\u0441\u043B\u043E\u0442\u0430"
  _description: "<b>H<size=60%><b>3</b></size>PO<size=60%><b>4</b></size></b>. \u041D\u0435\xAD\u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0430\u044F
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430 \u0441\u0440\u0435\u0434\xAD\u043D\u0435\u0439
    \u0441\u0438\xAD\u043B\u044B, \u043E\u0442\u0432\u0435\xAD\u0447\u0430\xAD\u044E\xAD\u0449\u0430\u044F
    \u0432\u044B\u0441\xAD\u0448\u0435\u0439 \u0441\u0442\u0435\xAD\u043F\u0435\xAD\u043D\u0438
    \u043E\u043A\u0438\u0441\xAD\u043B\u0435\xAD\u043D\u0438\u044F \u0444\u043E\u0441\xAD\u0444\u043E\xAD\u0440\u0430
    (+5). \u041F\u0440\u0438 \u0441\u0442\u0430\u043D\xAD\u0434\u0430\u0440\u0442\xAD\u043D\u044B\u0445
    \u0443\u0441\u043B\u043E\xAD\u0432\u0438\xAD\u044F\u0445 \u043F\u0440\u0435\u0434\xAD\u0441\u0442\u0430\u0432\xAD\u043B\u044F\xAD\u0435\u0442
    \u0441\u043E\xAD\u0431\u043E\u0439 \u0442\u0432\u0435\u0440\xAD\u0434\u044B\u0435
    \u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u044B\u0435 \u0433\u0438\u0433\xAD\u0440\u043E\xAD\u0441\u043A\u043E\xAD\u043F\u0438\u0447\xAD\u043D\u044B\u0435
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u044B. \u041E\u0431\u044B\u0447\xAD\u043D\u043E
    \u043E\u0440\xAD\u0442\u043E\xAD\u0444\u043E\u0441\xAD\u0444\u043E\u0440\xAD\u043D\u043E\u0439
    (\u0438\u043B\u0438 \u043F\u0440\u043E\u0441\xAD\u0442\u043E \u0444\u043E\u0441\xAD\u0444\u043E\u0440\xAD\u043D\u043E\u0439)
    \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u043E\u0439 \u043D\u0430\xAD\u0437\u044B\xAD\u0432\u0430\xAD\u044E\u0442
    85 % \u0432\u043E\u0434\xAD\u043D\u044B\u0439 \u0440\u0430\u0441\xAD\u0442\u0432\u043E\u0440
    (\u0431\u0435\u0441\xAD\u0446\u0432\u0435\u0442\xAD\u043D\u0430\u044F \u0441\u0438\xAD\u0440\u043E\xAD\u043F\u043E\xAD\u043E\u0431\xAD\u0440\u0430\u0437\xAD\u043D\u0430\u044F
    \u0436\u0438\u0434\xAD\u043A\u043E\u0441\u0442\u044C \u0431\u0435\u0437 \u0437\u0430\xAD\u043F\u0430\xAD\u0445\u0430).
    \u0420\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0438\xAD\u043C\u0430 \u0432
    \u044D\u0442\u0430\xAD\u043D\u043E\xAD\u043B\u0435 \u0438 \u0434\u0440\u0443\xAD\u0433\u0438\u0445
    \u0440\u0430\u0441\xAD\u0442\u0432\u043E\xAD\u0440\u0438\xAD\u0442\u0435\xAD\u043B\u044F\u0445."
