  _header: "\u0413\u043B\u0438\u0446\u0438\u043D"
  _description: "<b>C<size=60%><b>2</b></size>H<size=60%><b>5</b></size>NO<size=60%><b>2</b></size></b>.
    \u041F\u0440\u043E\u0441\xAD\u0442\u0435\u0439\xAD\u0448\u0430\u044F \u0443\u0441\u0442\u043E\u0439\xAD\u0447\u0438\xAD\u0432\u0430\u044F
    \u0430\u043C\u0438\xAD\u043D\u043E\xAD\u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0442\u0430,
    \u0432\u0445\u043E\xAD\u0434\u0438\u0442 \u0432 \u0433\u0440\u0443\u043F\xAD\u043F\u0443
    \u0437\u0430\xAD\u043C\u0435\xAD\u043D\u0438\xAD\u043C\u044B\u0445 \u0430\u043C\u0438\xAD\u043D\u043E\xAD\u043A\u0438\u0441\xAD\u043B\u043E\u0442
    (\u0441\u0438\u043D\xAD\u0442\u0435\xAD\u0437\u0438\xAD\u0440\u0443\xAD\u0435\u0442\xAD\u0441\u044F
    \u043E\u0440\xAD\u0433\u0430\xAD\u043D\u0438\u0437\xAD\u043C\u043E\u043C \u0447\u0435\xAD\u043B\u043E\xAD\u0432\u0435\xAD\u043A\u0430
    \u0438 \u043C\u043B\u0435\xAD\u043A\u043E\xAD\u043F\u0438\xAD\u0442\u0430\xAD\u044E\xAD\u0449\u0438\u0445).
    \u041A\u0440\u043E\xAD\u043C\u0435 \u0442\u043E\xAD\u0433\u043E \u0433\u043B\u0438\xAD\u0446\u0438\u043D
    \u2013 \u043F\u0440\u043E\xAD\u043C\u0435\xAD\u0436\u0443\xAD\u0442\u043E\u0447\xAD\u043D\u044B\u0439
    \u043C\u0435\xAD\u0442\u0430\xAD\u0431\u043E\xAD\u043B\u0438\u0442 \u043C\u043D\u043E\xAD\u0433\u0438\u0445
    \u0434\u0440\u0443\xAD\u0433\u0438\u0445 \u0431\u0438\u043E\xAD\u043B\u043E\xAD\u0433\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0438
    \u0432\u0430\u0436\xAD\u043D\u044B\u0445 \u0441\u043E\xAD\u0435\u0434\u0438\xAD\u043D\u0435\xAD\u043D\u0438\u0439,
    \u043D\u0430\xAD\u043F\u0440\u0438\xAD\u043C\u0435\u0440, \u043F\u0443\xAD\u0440\u0438\xAD\u043D\u043E\xAD\u0432\u044B\u0445
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0439w (\u0441\u043E\xAD\u0441\u0442\u0430\u0432\xAD\u043D\u044B\u0445
    \u0447\u0430\u0441\xAD\u0442\u0435\u0439 \u043D\u0443\u043A\xAD\u043B\u0435\xAD\u0438\xAD\u043D\u043E\xAD\u0432\u044B\u0445
    \u043A\u0438\u0441\xAD\u043B\u043E\u0442)."
