  m_Name: SO_RE_Activated carbon
  m_EditorClassIdentifier: 
  _header: "\u0410\u043A\u0442\u0438\u0432\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0443\u0433\u043E\u043B\u044C"
  _description: "\u041E\u0434\xAD\u043D\u0430 \u0438\u0437 \u0444\u043E\u0440\u043C
    \u0443\u0433\xAD\u043B\u0435\xAD\u0440\u043E\xAD\u0434\u0430 \u0441 \u043D\u0435\xAD\u0441\u043E\xAD\u0432\u0435\u0440\xAD\u0448\u0435\u043D\xAD\u043D\u043E\u0439
    \u0441\u0442\u0440\u0443\u043A\xAD\u0442\u0443\xAD\u0440\u043E\u0439, \u043F\u0440\u0430\u043A\xAD\u0442\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0438
    \u043D\u0435 \u0441\u043E\xAD\u0434\u0435\u0440\xAD\u0436\u0430\xAD\u0449\u0430\u044F
    \u043F\u0440\u0438\xAD\u043C\u0435\xAD\u0441\u0435\u0439. \u0410\u043A\xAD\u0442\u0438\xAD\u0432\u0438\xAD\u0440\u043E\xAD\u0432\u0430\u043D\xAD\u043D\u044B\u0439
    \u0443\u0433\u043E\u043B\u044C \u043D\u0430 87-97 % \u043F\u043E \u043C\u0430\u0441\xAD\u0441\u0435
    \u0441\u043E\xAD\u0441\u0442\u043E\xAD\u0438\u0442 \u0438\u0437 \u0443\u0433\xAD\u043B\u0435\xAD\u0440\u043E\xAD\u0434\u0430,
    \u0442\u0430\u043A\xAD\u0436\u0435 \u043C\u043E\xAD\u0436\u0435\u0442 \u0441\u043E\xAD\u0434\u0435\u0440\xAD\u0436\u0430\u0442\u044C
    \u0432\u043E\xAD\u0434\u043E\xAD\u0440\u043E\u0434, \u043A\u0438\u0441\xAD\u043B\u043E\xAD\u0440\u043E\u0434,
    \u0430\u0437\u043E\u0442, \u0441\u0435\xAD\u0440\u0443 \u0438 \u0434\u0440\u0443\xAD\u0433\u0438\u0435
    \u0432\u0435\xAD\u0449\u0435\u0441\u0442\xAD\u0432\u0430."
  _sprite: {fileID: 21300000, guid: 05e5d3464ce124c4cabbf6a96dc45d40, type: 3}
