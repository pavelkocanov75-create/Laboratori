  m_Name: SO_RE_Potassium ferricyanide
  m_EditorClassIdentifier: 
  _header: "\u0424\u0435\u0440\u0440\u0438\u0446\u0438\u0430\u043D\u0438\u0434 \u043A\u0430\u043B\u0438\u044F"
  _description: "<b>K<size=60%><b>4</b></size>F<size=85%><b>e</b></size>(CN)</b>.
    \u0421\u0432\u0435\u0442\xAD\u043B\u043E-\u0436\u0435\u043B\xAD\u0442\u044B\u0439
    \u043C\u043E\xAD\u043D\u043E\u043A\xAD\u043B\u0438\u043D\xAD\u043D\u044B\u0439
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\u043B \u0438\u043B\u0438 \u043F\u043E\xAD\u0440\u043E\xAD\u0448\u043E\u043A
    \u0431\u0435\u0437 \u0437\u0430\xAD\u043F\u0430\xAD\u0445\u0430, \u0441\u043B\u0435\u0433\xAD\u043A\u0430
    \u0441\u043E\xAD\u043B\u0435\xAD\u043D\u044B\u0439, \u0441 \u043E\u0442\xAD\u043D\u043E\xAD\u0441\u0438\xAD\u0442\u0435\u043B\u044C\xAD\u043D\u043E\u0439
    \u043F\u043B\u043E\u0442\xAD\u043D\u043E\u0441\u0442\u044C\u044E 1,85. \u041E\u043D
    \u0441\u0442\u0430\xAD\u0431\u0438\xAD\u043B\u0435\u043D \u043F\u0440\u0438 \u043A\u043E\u043C\xAD\u043D\u0430\u0442\xAD\u043D\u043E\u0439
    \u0442\u0435\u043C\xAD\u043F\u0435\xAD\u0440\u0430\xAD\u0442\u0443\xAD\u0440\u0435
    \u0438 \u043D\u0430\xAD\u0447\u0438\xAD\u043D\u0430\xAD\u0435\u0442 \u0442\u0435\xAD\u0440\u044F\u0442\u044C
    \u043A\u0440\u0438\u0441\xAD\u0442\u0430\u043B\xAD\u043B\u0438\xAD\u0447\u0435\u0441\xAD\u043A\u0443\u044E
    \u0432\u043E\xAD\u0434\u0443 \u043F\u0440\u0438 \u043D\u0430\xAD\u0433\u0440\u0435\xAD\u0432\u0430\xAD\u043D\u0438\u0438
    \u0434\u043E 70 \xB0 C."
